# ============================================================
#  NexPDFCoX — Environment Variables EXAMPLE
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values in .env
#  3. NEVER commit .env — it is git-ignored
# ============================================================

# ── Google AdSense ────────────────────────────────────────────
VITE_ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXXX

# ── Ad Slot IDs ───────────────────────────────────────────────
# Get from: https://adsense.google.com → Ads → By ad unit → Create ad unit

VITE_AD_SLOT_HORIZONTAL=YOUR_HORIZONTAL_SLOT_ID
VITE_AD_SLOT_RECTANGLE=YOUR_RECTANGLE_SLOT_ID
VITE_AD_SLOT_VERTICAL=YOUR_VERTICAL_SLOT_ID
VITE_AD_SLOT_LEFT_SIDEBAR=YOUR_LEFT_SIDEBAR_SLOT_ID
VITE_AD_SLOT_RESPONSIVE=YOUR_RESPONSIVE_SLOT_ID

# ── Site Config ───────────────────────────────────────────────
VITE_SITE_URL=https://nexpdfcox.vercel.app

# ── Analytics (Optional) ─────────────────────────────────────
VITE_GA4_ID=G-XXXXXXXXXX
